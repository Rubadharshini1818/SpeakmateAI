# ── SpeakMate AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=speakmate_db
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password_here

# JWT secret — must be at least 32 characters
JWT_SECRET=SpeakMateAISuperSecretKeyThatMustBeAtLeast32BytesLongForSecurityReasons
JWT_EXPIRATION_MS=86400000

# Groq API key (get one free at https://console.groq.com/keys)
# Key format: gsk_...
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_MODEL=llama-3.3-70b-versatile
